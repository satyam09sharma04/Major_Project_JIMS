# ------------------------------
# Blockchain Environment Config
# ------------------------------

# Deployer account private key (without 0x if your config expects raw; with 0x is also common)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RPC endpoints
LOCAL_RPC_URL=http://127.0.0.1:8545
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_project_id
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Optional explorer API keys for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Optional deployment defaults
CHAIN_ID_LOCAL=31337
CHAIN_ID_SEPOLIA=11155111
CHAIN_ID_AMOY=80002

# Contract addresses (used by scripts/interact.js fallback when deployment manifest is absent)
PROPERTY_REGISTRY_ADDRESS=
OWNERSHIP_TRANSFER_ADDRESS=
PROPERTY_HISTORY_ADDRESS=

